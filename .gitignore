scraper/*.session
scraper/output/

# Eval harness generated outputs (can be large; contains generated apps)
scripts/eval/results/

# Lockfile is platform-specific (Mac) and breaks Linux CI native bindings
# (@tailwindcss/oxide). Let npm install resolve per-platform on deploy.
package-lock.json

# Ruflo / claude-flow local tooling state — machine-specific, never commit
.claude-flow/
.swarm/
.agents/
.claude/
.mcp.json
agentdb.rvf
agentdb.rvf.lock
ruvector.db
skills-lock.json
CLAUDE.md.pre-ruflo

# Python bytecode
__pycache__/


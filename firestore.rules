rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ────────────────────────────────────────────────────────────────
    // Users can only read/write their own profile document.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Projects ─────────────────────────────────────────────────────────────
    // Users can only access projects they own.
    match /projects/{projectId} {
      allow read, update, delete: if request.auth != null
        && request.auth.uid == resource.data.userId;

      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.userId;

      // ── Messages (subcollection) ──────────────────────────────────────────
      // Only the project owner can read/write messages on their project.
      match /messages/{messageId} {
        allow read, write: if request.auth != null
          && request.auth.uid == get(/databases/$(database)/documents/projects/$(projectId)).data.userId;
      }
    }

    // ── Corpus submissions (admin only) ──────────────────────────────────────
    match /corpus_submissions/{docId} {
      allow read, write: if request.auth != null
        && request.auth.token.email == 'gandoadlam25@gmail.com';
    }

    // ── ADLaM dictionary (admin only) ────────────────────────────────────────
    match /adlam_dict/{docId} {
      allow read, write: if request.auth != null
        && request.auth.token.email == 'gandoadlam25@gmail.com';
    }

    // ── Health check (unauthenticated ping) ──────────────────────────────────
    match /test/connection {
      allow read: if true;
    }
  }
}

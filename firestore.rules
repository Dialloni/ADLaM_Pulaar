rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Admin = bootstrap email or a doc in /admins. Mirrors AuthContext.tsx.
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'gandoadlam25@gmail.com'
        || exists(/databases/$(database)/documents/admins/$(request.auth.token.email))
      );
    }

    // ── Users ────────────────────────────────────────────────────────────────
    // Users can only read/write their own profile document.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Projects ─────────────────────────────────────────────────────────────
    // Owners access their own; anyone logged in can read FEATURED (community
    // gallery); admins can read/update any (moderation).
    match /projects/{projectId} {
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.userId
        || resource.data.featured == true
        || isAdmin()
      );

      allow update, delete: if request.auth != null && (
        request.auth.uid == resource.data.userId
        || isAdmin()
      );

      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.userId;

      // ── Messages (subcollection) ──────────────────────────────────────────
      // Only the project owner can read/write messages on their project.
      match /messages/{messageId} {
        allow read, write: if request.auth != null
          && request.auth.uid == get(/databases/$(database)/documents/projects/$(projectId)).data.userId;
      }

      // ── Form submissions (subcollection) ──────────────────────────────────
      // Written ONLY by the server (Admin SDK) via /api/submit/<id>.
      // Owner reads and deletes; nobody creates or edits from the client.
      match /submissions/{submissionId} {
        allow read, delete: if request.auth != null
          && request.auth.uid == get(/databases/$(database)/documents/projects/$(projectId)).data.userId;
        allow create, update: if false;
      }
    }

    // ── Chats ────────────────────────────────────────────────────────────────
    // Chat-mode conversation threads. Owner-only; messages stored inline.
    match /chats/{chatId} {
      allow read, update, delete: if request.auth != null
        && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.userId;
    }

    // ── Publish slugs ─────────────────────────────────────────────────────────
    // Doc ID = the slug (/p/<slug>). Claimed client-side in a transaction;
    // create only if free, delete only by the claimer. Never updated in place.
    // Public serving reads via the Admin SDK (bypasses these rules).
    match /slugs/{slug} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.userId
        && slug.matches('[a-z0-9][a-z0-9-]{1,38}[a-z0-9]');
      allow delete: if request.auth != null
        && request.auth.uid == resource.data.userId;
    }

    // ── Corpus submissions ────────────────────────────────────────────────────
    // Crowdsourced: any signed-in user may SUBMIT (collector), but only as an
    // unverified draft — they cannot self-verify or backdate authorship.
    // Reading, verifying (update), and deleting are admin-only: the corpus is
    // the core asset, so no ordinary user can read it wholesale or destroy it.
    match /corpus_submissions/{docId} {
      allow read: if isAdmin();
      allow create: if request.auth != null
        && request.resource.data.status in ['pending', 'needs_adlam']
        && request.resource.data.verified_by == null
        // Bind authorship to the caller (no forging someone else's email) and
        // cap the text field so the review queue can't be flooded with giant docs.
        && request.resource.data.source_meta.submitted_by == request.auth.token.email
        && request.resource.data.raw_text is string
        && request.resource.data.raw_text.size() < 10000;
      allow update, delete: if isAdmin();
    }

    // ── ADLaM dictionary ─────────────────────────────────────────────────────
    // Public read (it's a glossary, not private data); only admins may write.
    match /adlam_dict/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // ── Corpus categories ────────────────────────────────────────────────────
    // Shared category list. Any logged-in user may read (chips) and add a new
    // one (must carry a slug + English label); only admins edit/remove.
    match /corpus_categories/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.slug is string
        && request.resource.data.slug.size() < 60
        && request.resource.data.en is string
        && request.resource.data.en.size() < 80;
      allow update, delete: if isAdmin();
    }

    // ── Admins list (read: any logged-in user to check own status) ───────────
    match /admins/{email} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── Runtime config (admin kill switches: daily limits, shared API key) ───
    // Server reads via Admin SDK (bypasses rules); this gates the admin portal.
    match /config/{docId} {
      allow read, write: if isAdmin();
    }

    // ── Token usage totals (admin dashboard) — server-written via Admin SDK. ──
    match /usage_tokens/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ── Health check (unauthenticated ping) ──────────────────────────────────
    match /test/connection {
      allow read: if true;
    }
  }
}

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Admin = bootstrap email or a doc in /admins. Mirrors AuthContext.tsx.
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'gandoadlam25@gmail.com'
        || exists(/databases/$(database)/documents/admins/$(request.auth.token.email))
      );
    }

    // ── Users ────────────────────────────────────────────────────────────────
    // Users can only read/write their own profile document.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Projects ─────────────────────────────────────────────────────────────
    // Owners access their own; anyone logged in can read FEATURED (community
    // gallery); admins can read/update any (moderation).
    match /projects/{projectId} {
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.userId
        || resource.data.featured == true
        || isAdmin()
      );

      allow update, delete: if request.auth != null && (
        request.auth.uid == resource.data.userId
        || isAdmin()
      );

      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.userId;

      // ── Messages (subcollection) ──────────────────────────────────────────
      // Only the project owner can read/write messages on their project.
      match /messages/{messageId} {
        allow read, write: if request.auth != null
          && request.auth.uid == get(/databases/$(database)/documents/projects/$(projectId)).data.userId;
      }
    }

    // ── Chats ────────────────────────────────────────────────────────────────
    // Chat-mode conversation threads. Owner-only; messages stored inline.
    match /chats/{chatId} {
      allow read, update, delete: if request.auth != null
        && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.userId;
    }

    // ── Corpus submissions (any authenticated user) ───────────────────────────
    // Admin UI is gated by email check in frontend — Firestore just requires login
    match /corpus_submissions/{docId} {
      allow read, write: if request.auth != null;
    }

    // ── ADLaM dictionary (any authenticated user) ────────────────────────────
    match /adlam_dict/{docId} {
      allow read, write: if request.auth != null;
    }

    // ── Admins list (read: any logged-in user to check own status) ───────────
    match /admins/{email} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── Health check (unauthenticated ping) ──────────────────────────────────
    match /test/connection {
      allow read: if true;
    }
  }
}

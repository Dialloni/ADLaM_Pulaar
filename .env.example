# ── Gemini AI (server-side, never VITE_ prefix) ──────────────────────────────
# Required for all AI generation endpoints.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Optional overrides
# GEMINI_MODEL="gemini-2.5-flash"
# GEMINI_MAX_OUTPUT_TOKENS="32768"

# ── Firebase Client SDK (browser-side, VITE_ prefix required) ────────────────
# Get these from Firebase Console → Project Settings → Your apps → Web app
VITE_FIREBASE_API_KEY="MY_FIREBASE_API_KEY"
VITE_FIREBASE_AUTH_DOMAIN="MY_PROJECT.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="MY_PROJECT_ID"
VITE_FIREBASE_STORAGE_BUCKET="MY_PROJECT.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="MY_SENDER_ID"
VITE_FIREBASE_APP_ID="MY_APP_ID"
VITE_FIREBASE_FIRESTORE_DATABASE_ID="MY_FIRESTORE_DB_ID"

# ── Firebase Admin SDK (server-side only, never VITE_ prefix) ────────────────
# Download from Firebase Console → Project Settings → Service accounts → Generate new private key
# Paste the entire JSON content as a single line (minified), wrapped in single quotes.
FIREBASE_SERVICE_ACCOUNT='{"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}'

# ── App ───────────────────────────────────────────────────────────────────────
APP_URL="http://localhost:3000"

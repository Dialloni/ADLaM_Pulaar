{
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/generate", "destination": "/api/generate" },
    { "source": "/api/edit", "destination": "/api/edit" },
    { "source": "/api/transcribe", "destination": "/api/transcribe" },
    { "source": "/api/status", "destination": "/api/status" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/*.ts": {
      "maxDuration": 60
    }
  }
}

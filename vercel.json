{
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/__/auth/:path*", "destination": "https://ai-studio-applet-webapp-28b0a.firebaseapp.com/__/auth/:path*" },
    { "source": "/__/firebase/:path*", "destination": "https://ai-studio-applet-webapp-28b0a.firebaseapp.com/__/firebase/:path*" },
    { "source": "/api/generate", "destination": "/api/generate" },
    { "source": "/api/edit", "destination": "/api/edit" },
    { "source": "/api/transcribe", "destination": "/api/transcribe" },
    { "source": "/api/status", "destination": "/api/status" },
    { "source": "/api/ocr", "destination": "/api/ocr" },
    { "source": "/api/decode", "destination": "/api/decode" },
    { "source": "/api/translate", "destination": "/api/translate" },
    { "source": "/p/:id", "destination": "/api/p/:id" },
    { "source": "/api/submit/:id", "destination": "/api/submit/:id" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/*.ts": {
      "maxDuration": 300,
      "memory": 1024
    }
  }
}

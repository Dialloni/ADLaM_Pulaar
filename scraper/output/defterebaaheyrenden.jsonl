{"text": "𞤔𞤢𞤲𞤺𞤭𞤲 𞤖𞤫𞤤𞥆𞤮𞤤 𞥓𞥐⹁ 𞤋𞤲𞤯𞤫 𞤙𞤢𞥄𞤤𞤯𞤭 𞤯𞤭𞤲:", "source": "defterebaaheyrenden", "message_id": 53, "date": "2020-05-25T15:12:47+00:00", "adlam_ratio": 0.931}
{"text": "𞤔𞤢𞤲𞤺𞤭𞤲 𞤖𞤫𞤤𞥆𞤮𞤤 𞥒𞥙⹁ 𞤄𞤮𞥅𞤦𞤮 𞤆𞤵𞤤𞥆𞤮", "source": "defterebaaheyrenden", "message_id": 51, "date": "2020-05-25T15:11:21+00:00", "adlam_ratio": 0.96}
{"text": "𞤔𞤢𞤲𞤺𞤭𞤲 𞤸𞤫𞤤𞥆𞤮𞤤 𞥒𞥘, 𞤃𞤭𞥅𞤶𞤭𞤼𞤭𞥅 𞤥𞤭", "source": "defterebaaheyrenden", "message_id": 49, "date": "2020-05-25T15:09:44+00:00", "adlam_ratio": 0.96}
{"text": "𞤖𞤫𞤤𞥆𞤮𞤤 𞥒𞥗⹁ 𞤀𞤪𞤼𞤫𞤲 𞤫 𞤭𞤱𞤣𞤭 𞤥𞤫𞤲.", "source": "defterebaaheyrenden", "message_id": 47, "date": "2020-05-23T16:50:15+00:00", "adlam_ratio": 0.913}
{"text": "𞤖𞤫𞤤𞥆𞤮𞤤 𞥒𞥖⹁ 𞤀𞤪𞤼𞤫𞤲 𞤫𞥅 𞤭𞤱𞤣𞤭 𞤥𞤫𞤲.", "source": "defterebaaheyrenden", "message_id": 46, "date": "2020-05-23T16:45:38+00:00", "adlam_ratio": 0.9167}
{"text": "𞤖𞤫𞤤𞥆𞤮𞤤 𞥒𞥕⹁ 𞤊𞤭𞥅𞤲𞤢𞤲𞤣𞤫 𞤓𞥅 𞤵𞥅.", "source": "defterebaaheyrenden", "message_id": 44, "date": "2020-05-23T16:39:41+00:00", "adlam_ratio": 0.9091}
{"text": "𞤖𞤫𞤤𞥆𞤮𞤤 𞥒𞥔⹁ 𞤬𞤭𞥅𞤲𞤢𞤲𞤣𞤫 𞤓𞥅 𞤵𞥅.", "source": "defterebaaheyrenden", "message_id": 43, "date": "2020-05-23T16:37:28+00:00", "adlam_ratio": 0.9091}
{"text": "𞤖𞤫𞤤𞥆𞤮𞤤 𞥒𞥓⹁ 𞤊𞤭𞥅𞤲𞤢𞤲𞤣𞤫 𞤓 𞤵.", "source": "defterebaaheyrenden", "message_id": 41, "date": "2020-05-23T16:31:54+00:00", "adlam_ratio": 0.9}
{"text": "𞤖𞤫𞤤𞥆𞤮𞤤 𞥒𞥒, 𞤊𞤭𞥅𞤲𞤢𞤲𞤣𞤫 𞤓 𞤵.", "source": "defterebaaheyrenden", "message_id": 40, "date": "2020-05-23T16:30:47+00:00", "adlam_ratio": 0.9}
{"text": "𞤖𞤫𞤤𞥆𞤮𞤤 𞥒𞥑 𞤊𞤭𞥅𞤲𞤢𞤲𞤣𞤫 𞤌𞥅 𞤮𞥅.", "source": "defterebaaheyrenden", "message_id": 38, "date": "2020-05-23T16:22:09+00:00", "adlam_ratio": 0.9524}
{"text": "𞤖𞤫𞤤𞥆𞤮𞤤 𞥒𞥐  𞤊𞤭𞥅𞤲𞤢𞤲𞤣𞤫  𞤌𞥅 𞤮𞥅.", "source": "defterebaaheyrenden", "message_id": 37, "date": "2020-05-23T16:21:06+00:00", "adlam_ratio": 0.9524}
{"text": "𞤖𞤫𞤤𞥆𞤮𞤤 𞥑𞥙", "source": "defterebaaheyrenden", "message_id": 35, "date": "2020-05-22T23:09:34+00:00", "adlam_ratio": 1.0}
